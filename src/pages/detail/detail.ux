  margin-top: 26px;
  flex-direction: column;
  width: 100%;
  align-items: center;
}

.detail__title {
  font-size: 24px;
  font-weight: bold;
}

.detail__subtitle {
  font-size: 24px;
  margin-top: 3px;
  color: rgba(255, 255, 255, 0.75);
}

.detail__item-value {
  font-size: 36px;
  font-weight: bold;
  margin-left: -1px;
}

.detail__item-label {
  font-size: 24px;
  margin-top: 2px;
  color: rgba(255, 255, 255, 0.75);
}

.detail__card-title {
  font-size: 26px;
  font-weight: bold;
  margin-bottom: 12px;
  color: rgba(255, 255, 255, 0.75);
}

.detail__card {
  width: 100%;
  flex-direction: column;
  color: #ffffff;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 24px;
  padding: 12px;
  margin-top: 12px;
}

.detail__card-content {
  width: 100%;
  margin-top: -14px;
  flex-direction: column;
}

.detail__item {
  flex-direction: column;
  margin-top: 14px;
}

.detail__card-grid {
  flex-direction: column;
}

/* 针对圆表 */
@media (shape: circle) {
  .detail__content {
    padding: 0px 8px 88px 8px;
  }

  .detail__title {
    font-size: 36px;
    font-weight: normal;
  }

  .detail__subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .detail__item-value {
    font-size: 36px;
    font-weight: bold;
    margin-left: -1px;
  }

  .detail__item-label {
    font-size: 26px;
    margin-top: 2px;
    color: rgba(255, 255, 255, 0.75);
  }

  .detail__card-title {
    font-size: 28px;
  }

  .detail__card {
    width: 90%;
    border-radius: 32px;
    padding: 24px;
  }

  .detail__card-grid {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .detail__item {
    width: 49%;
    margin-left: 2px;
  }

  .detail__card-content {
    margin-left: -2px;
  }
}

/* 针对REDMI Watch 5/6 (分辨率: 432*514, 水平dp值: 216) */
@media (width: 216) {
  .detail__content {
    padding: 0px 8px 32px 8px;
  }

  .detail__title {
    font-size: 36px;
    font-weight: normal;
  }

  .detail__subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .detail__item-value {
    font-size: 36px;
    font-weight: bold;
    margin-left: -1px;
  }

  .detail__item-label {
    font-size: 26px;
    margin-top: 2px;
    color: rgba(255, 255, 255, 0.75);
  }

  .detail__card-title {
    font-size: 28px;
  }

  .detail__card {
    border-radius: 32px;
    padding: 24px;
  }

  .detail__card-grid {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .detail__item {
    width: 49%;
    margin-left: 2px;
  }

  .detail__card-content {
    margin-left: -2px;
  }
}

/* 针对小米手环9 Pro (分辨率: 336*480, 水平dp值: 160) */
@media (width: 160) {
  .detail__content {
    padding: 0px 8px 16px 8px;
  }

  .detail__title {
    font-size: 36px;
    font-weight: normal;
  }

  .detail__subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .detail__item-value {
    font-size: 36px;
    font-weight: bold;
    margin-left: -1px;
  }

  .detail__item-label {
    font-size: 26px;
