  flex-direction: column;
}

.title__location {
  width: 100%;
  line-height: 24px;
  font-size: 24px;
  font-weight: bold;
  color: white;
  text-align: center;
}

.title__time {
  margin-top: 12px;
  line-height: 24px;
  width: 100%;
  font-size: 24px;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.75);
  text-align: center;
  justify-content: center;
  align-items: center;
}

.title__time-text {
  line-height: 24px;
  width: 100%;
  font-size: 24px;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.75);
  text-align: center;
}

.title__time-loading {
  width: 24px;
  height: 24px;
  animation-name: title__loading-rotate;
  animation-duration: 1s;
  animation-iteration-count: infinite;
  animation-timing-function: linear;
  transform-origin: 12px 12px;
}

@keyframes title__loading-rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.current {
  width: 100%;
  height: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.current__temperature {
  line-height: 96px;
  font-size: 96px;
  font-weight: bold;
  color: white;
  text-align: center;
}

.current__unit {
  height: 64px;
  margin-top: 4px;
  line-height: 64px;
  font-size: 64px;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

.current__weather {
  margin-top: 16px;
  line-height: 32px;
  width: 100%;
  font-size: 32px;
  color: rgba(255, 255, 255, 0.75);
  text-align: center;
}

.current__daily {
  margin-top: 14px;
  margin-left: 3px;
  line-height: 32px;
  width: 100%;
  font-size: 32px;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.75);
  text-align: center;
}

.alert {
  margin-bottom: 22px;
  flex-shrink: 0;
  flex-direction: column;
  align-items: center;
}

.alert__card {
  padding: 8px 12px 8px 12px;
  background-color: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  align-items: center;
  justify-content: center;
}

.alert__icon {
  width: 32px;
  height: 32px;
}

.forecast-hourly {
  width: 100%;
  height: 184px;
}

.forecast-hourly__page-shell {
  width: 100%;
  height: 100%;
  flex-direction: row;
  justify-content: center;
  padding: 0 16px;
}

.forecast-hourly__page {
  width: 100%;
  height: 100%;
  flex-direction: row;
  justify-content: space-between;
}

.forecast-hourly__item {
  flex-direction: column;
  align-items: center;
}

.forecast-hourly__time {
  line-height: 28px;
  font-size: 28px;
  color: rgba(255, 255, 255, 0.75);
  lines: 1;
}

.forecast-hourly__temperature {
  margin-top: 42px;
  line-height: 28px;
  font-size: 28px;
  color: white;
}

.forecast-hourly__icon {
  margin-top: 38px;
}

.forecast-daily {
  margin-bottom: -12px;
  width: 100%;
  padding: 0 16px;
  flex-direction: column;
  align-items: center;
}

.forecast-daily__item {
  width: 100%;
  flex-direction: column;
  margin-bottom: 12px;
  justify-content: center;
}

.forecast-daily__item--horizontal {
  flex-direction: row;
