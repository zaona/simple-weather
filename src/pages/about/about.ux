  font-size: 30px;
  font-weight: bold;
  text-align: center;
  margin-bottom: 4px;
}

.about__app-version {
  font-size: 24px;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
}

