  flex-direction: column;
  align-items: center;
}

.no-data__qr-tip {
  width: 100%;
  font-size: 24px;
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
}

.no-data__qr-box {
  width: 100%;
  margin-top: 16px;
  padding: 8px;
  flex-direction: column;
  align-items: center;
  border-radius: 8px;
  background-color: #ffffff;
}

.no-data__qr-code {
  color: #000000;
  background-color: #ffffff;
}

/* 针对圆表 */
@media (shape: circle) {
  .no-data__content {
    padding: 0px 8px 88px 8px;
  }

  .no-data__title {
    font-size: 36px;
    font-weight: normal;
  }

  .no-data__subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .no-data__card {
    width: 90%;
    border-radius: 32px;
    padding: 24px;
  }

  .no-data__desc {
    font-size: 30px;
  }

  .no-data__qr-tip {
    font-size: 30px;
  }

  .no-data__qr-box {
    width: 80%;
  }
}

/* 针对REDMI Watch 5/6 (分辨率: 432*514, 水平dp值: 216) */
@media (width: 216) {
  .no-data__content {
    padding: 0px 8px 32px 8px;
  }

  .no-data__title {
    font-size: 36px;
    font-weight: normal;
  }

  .no-data__subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .no-data__card {
    border-radius: 32px;
    padding: 24px;
  }

  .no-data__desc {
    font-size: 30px;
  }

  .no-data__qr-tip {
    font-size: 30px;
  }

  .no-data__qr-box {
    width: 80%;
  }
}

/* 针对小米手环9/10 Pro (分辨率: 336*480, 水平dp值: 160) */
@media (width: 160) {
  .no-data__content {
    padding: 0px 8px 16px 8px;
  }

  .no-data__title {
    font-size: 36px;
    font-weight: normal;
  }

  .no-data__subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .no-data__card {
    border-radius: 32px;
    padding: 24px;
  }

  .no-data__desc {
    font-size: 30px;
  }

  .no-data__qr-tip {
    font-size: 30px;
  }

  .no-data__qr-box {
    width: 80%;
  }
}
