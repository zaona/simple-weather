  padding: 18px 30px;
  border-radius: 50%;
}

.hero {
  flex-direction: column;
  align-items: center;
}

.mt-lg {
  margin-top: 12px;
}

/* 针对小米手环10 (分辨率: 212*520, 水平dp值: 106) */
@media (width: 106) {
  .section--hero {
    height: 520px;
  }
}

