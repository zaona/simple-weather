    color: rgba(255, 255, 255, 0.75);
  }

  .detail__card-title {
    font-size: 28px;
  }

  .detail__card {
    border-radius: 32px;
    padding: 24px;
  }

  .detail__card-grid {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .detail__item {
    width: 49%;
