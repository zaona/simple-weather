    justify-content: center;
    margin: 24px 0 24px -8px;
  }

  .about__app-icon {
    width: 100px;
    height: 100px;
    margin-bottom: 0;
    margin-right: 24px;
  }

  .about__app-text {
    align-items: flex-start;
  }

  .about__app-name {
    font-size: 36px;
    text-align: left;
  }

  .about__app-version {
