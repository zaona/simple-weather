<template>
  <div class="no-data">
    <scroll class="no-data__content" scroll-y="true" bounces="true">
      <div class="no-data__header">
        <text class="no-data__title">无数据</text>
        <text class="no-data__subtitle"></text>
      </div>

      <div class="no-data__card">
        <div class="no-data__card-content">
          <text class="no-data__desc" if="{{ mode === 'no_data' }}">请同步天气数据</text>
          <text class="no-data__desc" if="{{ mode === 'expired' && supportsAdvancedFeatures }}">
            本地数据已过期
          </text>
          <text class="no-data__desc" if="{{ mode === 'expired' && !supportsAdvancedFeatures }}">
            当前设备不支持自动更新
          </text>

          <div class="no-data__actions" if="{{ mode === 'expired' && supportsAdvancedFeatures }}">
            <div
              class="btn btn--secondary-square"
              onclick="requestRefresh()"
              if="{{ !isUpdating }}"
            >
              <text class="btn__text">尝试更新</text>
            </div>
            <div class="btn btn--secondary-square no-data__btn--spaced" if="{{ isUpdating }}">
              <text class="btn__text">更新中...</text>
            </div>
          </div>

          <div class="no-data__qr-section">
            <text class="no-data__qr-tip">扫码查看同步教程</text>
            <div class="no-data__qr-box">
              <qrcode
                class="no-data__qr-code"
                value="https://www.yuque.com/zaona/weather/syncer"
              ></qrcode>
            </div>
          </div>
        </div>
      </div>

      <!-- 调试面板（仅在调试模式下显示） -->
      <div class="no-data__card no-data__card--debug" if="{{ showDebugPanel }}">
        <div class="btn btn--secondary-square" @click="injectMockData">
          <text class="btn__text">模拟数据</text>
        </div>
        <div class="btn btn--secondary-square no-data__btn--spaced" @click="clearData">
          <text class="btn__text">清除数据</text>
        </div>
      </div>
    </scroll>
  </div>
</template>

<script>
/**
 * 无数据页面
 * 处理本地无数据和数据过期两种状态，提供手动刷新和同步教程
 */
import router from "@system.router"
import {showToast} from "@system.prompt"
const {
  ConnectionService,
  DataService,
  RefreshController,
  DeviceService,
  DebugService,
  DateUtils,
  MESSAGES,
  TOAST_DURATION,
  ADVANCED_FEATURE_PRODUCT_BLACKLIST,
  WEATHER_API_ERRORS
} = global

export default {
  private: {
    // ---- 页面状态 ----
    mode: "no_data",
    supportsAdvancedFeatures: false,

    // ---- 调试 ----
    showDebugPanel: false,

    // ---- 辅助 ----
    isUpdating: false,
    hasNavigated: false,
    navigationTimer: null
  },

  /**
   * 页面初始化
   * 检测设备能力并同步数据状态
   */
  async onInit() {
    this.showDebugPanel = DebugService.isDebugMode()
    await this.detectFeatureSupport()
    await this.syncState()
  },

  /**
   * 检测设备是否支持高级功能（逐小时预报、预警等）
   */
  async detectFeatureSupport() {
    try {
      this.supportsAdvancedFeatures = !(await DeviceService.isProductInList(
        ADVANCED_FEATURE_PRODUCT_BLACKLIST
      ))
    } catch (error) {
      console.error("检测设备能力失败:", error)
      this.supportsAdvancedFeatures = false
    }
  },

  /**
   * 页面显示时初始化连接，注册消息处理器
   */
  onShow() {
    ConnectionService.init((data) => {
      this.handleData(data)
    })
  },

  onHide() {
    this.clearNavigationTimer()
  },

  onDestroy() {
    this.clearNavigationTimer()
  },

  /**
   * 同步数据状态
   * 如果本地有可用数据则自动跳转到首页
   */
  async syncState() {
    const state = await this.resolveState()
    if (state.usable) {
      this.goToHome()
      return
    }
    this.mode = state.mode || "no_data"
  },

  /**
   * 解析当前数据状态
   * @returns {Promise<Object>} { usable, mode }
   */
  async resolveState() {
    const todayResult = await DataService.getTodayData(true)

    if (todayResult && todayResult.status === "success") {
      return {
        usable: true,
        mode: "no_data"
      }
    }

    if (todayResult && todayResult.status === "expired") {
      return {
        usable: false,
        mode: "expired"
      }
    }

    return {
      usable: false,
      mode: "no_data"
    }
  },

  /**
   * 在每日列表中查找今日数据
   * @param {Object} weatherData - 天气数据
   * @returns {Object|null}
   */
  findTodayData(weatherData) {
    const todayStr = DateUtils.getTodayString()
    return DataService.getDailyList(weatherData).find((day) => day.fxDate === todayStr) || null
  },

  /**
   * 检查天气数据中是否包含今日数据
   * @param {Object} weatherData - 天气数据
   * @returns {boolean}
   */
  hasTodayData(weatherData) {
    if (!DataService.validateWeatherData(weatherData)) {
      return false
    }

    const todayData = this.findTodayData(weatherData)
    if (!todayData) {
      return false
    }
    return true
  },

  /**
   * 手动请求刷新天气数据
   * 仅在数据过期且设备支持时可用，成功则跳转首页
   */
  async requestRefresh() {
    if (this.mode !== "expired" || this.isUpdating || !this.supportsAdvancedFeatures) {
      return
    }

    this.isUpdating = true
    try {
      const weatherData = await RefreshController.refreshWeatherData()
      if (this.hasTodayData(weatherData)) {
        showToast({
          message: MESSAGES.DATA_UPDATED,
          duration: TOAST_DURATION.SHORT
        })
        this.goToHomeAfterToast()
        return
      }

      showToast({
        message: MESSAGES.DATA_EXPIRED,
        duration: TOAST_DURATION.NORMAL
      })
    } catch (error) {
      const message =
        error?.code === "DATA_SAVE_FAILED"
          ? MESSAGES.DATA_SAVE_ERROR
          : error?.code === WEATHER_API_ERRORS.LOCATION_INFO_MISSING
          ? MESSAGES.LOCATION_INFO_MISSING
          : MESSAGES.FETCH_WEATHER_ERROR
      showToast({
        message,
        duration: TOAST_DURATION.NORMAL
      })
    } finally {
      this.isUpdating = false
    }
  },

  /**
   * 处理来自连接服务的实时数据
   * @param {Object} data - 接收到的消息数据
   */
  async handleData(data) {
    try {
      const weatherData = JSON.parse(data.data)

      if (!this.hasTodayData(weatherData)) {
        return
      }

      const saved = await DataService.saveWeatherData(JSON.stringify(weatherData))
      if (!saved) {
        return
      }

      showToast({
        message: MESSAGES.DATA_UPDATED,
        duration: TOAST_DURATION.SHORT
      })
      this.goToHomeAfterToast()
    } catch (error) {
      console.error("接收数据解析失败:", error)
      showToast({
        message: MESSAGES.DATA_PARSE_ERROR,
        duration: TOAST_DURATION.NORMAL
      })
    }
  },

  async injectMockData() {
    await DebugService.injectMockData()
  },

  async clearData() {
    await DebugService.clearLocalData()
  },

  /**
   * 清理延迟跳转定时器
   */
  clearNavigationTimer() {
    if (this.navigationTimer) {
      clearTimeout(this.navigationTimer)
      this.navigationTimer = null
    }
  },

  /**
   * 等待更新提示展示后跳转首页
   */
  goToHomeAfterToast() {
    if (this.hasNavigated || this.navigationTimer) {
      return
    }

    this.navigationTimer = setTimeout(() => {
      this.navigationTimer = null
      this.goToHome()
    }, TOAST_DURATION.SHORT)
  },

  /**
   * 跳转到首页
   * 使用 hasNavigated 标志防止重复跳转
   */
  goToHome() {
    if (this.hasNavigated) {
      return
    }
    this.hasNavigated = true

    router.replace({
      uri: "/pages/index"
    })
  }
}
</script>

