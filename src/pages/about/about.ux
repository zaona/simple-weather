@media (width: 233) or (width: 240) {
  .about__content {
    padding: 0px 8px 88px 8px;
  }

  .about__title {
    font-size: 36px;
    font-weight: normal;
  }

  .about__subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .about__setting-title {
    font-size: 30px;
  }

  .about__setting-subtitle {
    font-size: 24px;
    margin-top: 4px;
  }

  .about__card {
    width: 90%;
    border-radius: 32px;
    padding: 24px;
  }

  .about__app-icon {
    width: 100px;
    height: 100px;
  }

  .about__app-name {
    font-size: 36px;
  }

  .about__app-version {
    font-size: 30px;
  }

  .about__switch {
    width: 80px;
    height: 40px;
  }
}

/* 针对REDMI Watch 5/6 (分辨率: 432*514, 水平dp值: 216) */
@media (width: 216) {
  .about__content {
    padding: 0px 8px 32px 8px;
